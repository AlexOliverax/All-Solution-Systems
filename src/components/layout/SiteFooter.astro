---
import { getWhatsAppUrl, CONTACT_INFO } from '../../assets/js/contact-utils';

const whatsappUrl = getWhatsAppUrl();
const telegramUrl = CONTACT_INFO.telegram.url;
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white pt-16 pb-8 border-t border-gray-800">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Info Col -->
      <div class="col-span-1 md:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-3 text-white font-bold text-xl tracking-tight mb-6">
          <img src="/assets/img/logos/allsolutionsystems-light.png" alt="All Solution Systems" class="h-10 w-auto" loading="lazy" decoding="async" />
          <span>All Solution Systems</span>
        </a>
        <p class="text-gray-400 mb-6 leading-relaxed">
          Diagnóstico em 30 minutos e automação 24/7 para reduzir caos no atendimento e aumentar conversão.
        </p>
        <div class="flex items-center gap-4">
          <!-- WhatsApp Secundário -->
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent-whatsapp transition-colors" aria-label="WhatsApp">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM15.86 15.46L14.4 17.33C14.28 17.48 14.07 17.5 13.9 17.4C11.83 16.2 10.12 14.49 8.92 12.42C8.82 12.25 8.84 12.04 8.99 11.92L10.86 10.46C11.02 10.33 11.23 10.35 11.36 10.48L12.56 12.08C12.69 12.25 12.65 12.48 12.48 12.58L11.75 13.01C12.16 13.92 12.89 14.65 13.8 15.06L14.23 14.33C14.33 14.16 14.56 14.12 14.73 14.25L16.33 15.45C16.46 15.58 16.48 15.79 16.35 15.95L15.86 15.46Z" clip-rule="evenodd" />
            </svg>
          </a>
          <!-- Telegram Exigido -->
          <a href={telegramUrl} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-primary-light transition-colors" aria-label="Telegram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.33-.01-.98-.19-1.46-.35-.59-.19-.1-.32-.23-.51.93-.36 3.1-1.3 6.51-2.72 3.06-1.27 3.7-1.49 4.12-1.49.09 0 .3.02.41.13.09.09.12.21.12.35-.01.07-.02.16-.03.25z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links 1 -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6 uppercase tracking-wider text-sm">Empresa</h3>
        <ul class="space-y-4">
          <li><a href="/sobre/" class="text-gray-400 hover:text-white transition-colors">Sobre a All Solution</a></li>
          <li><a href="/b20/" class="text-gray-400 hover:text-white transition-colors">A Tecnologia B20</a></li>
          <li><a href="/casos-de-uso/" class="text-gray-400 hover:text-white transition-colors">Casos de Uso</a></li>
        </ul>
      </div>

      <!-- Links 2 -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6 uppercase tracking-wider text-sm">Soluções</h3>
        <ul class="space-y-4">
          <li><a href="/#lead247" class="text-gray-400 hover:text-white transition-colors">Diagnóstico (30 min)</a></li>
          <li><a href="/produtos/" class="text-gray-400 hover:text-white transition-colors">Produtos</a></li>
          <li><a href="/servicos/" class="text-gray-400 hover:text-white transition-colors">Serviços</a></li>
        </ul>
      </div>
      
      <!-- Contato Rápido & Legal -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6 uppercase tracking-wider text-sm">Atendimento</h3>
        <ul class="space-y-4">
          <li><a href="/contato/" class="text-gray-400 hover:text-white transition-colors">Fale Conosco</a></li>
          <li><a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">WhatsApp 11 96862-8280</a></li>
          <li><a href="mailto:contato@allsolutionsystems.com.br" class="text-gray-400 hover:text-white transition-colors">contato@allsolutionsystems.com.br</a></li>
          <li><a href="/privacidade/" class="text-gray-400 hover:text-white transition-colors">Política de Privacidade/LGPD</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between text-gray-500 text-sm">
      <p>&copy; {currentYear} All Solution Systems. Todos os direitos reservados.</p>
      <p class="mt-4 md:mt-0 flex gap-4">
        <a href="/privacidade/" class="hover:text-white transition-colors">Privacidade</a>
        <span>·</span>
        <a href="/contato/" class="hover:text-white transition-colors">Contato</a>
      </p>
    </div>
  </div>
</footer>
