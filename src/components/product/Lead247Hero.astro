---
// Lead 24/7 hero + form (MVP)
const WEBHOOK_URL = 'https://n8n.allsolutionsystems.com.br/webhook/lead-247';
const NICHOS = [
  'Estética',
  'Clínica',
  'Pet',
  'Assistência celular',
  'Automação/Robótica',
  'Outro',
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-brand-purple/10 to-white">
  <div class="container mx-auto px-4 py-16 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7">
        <div class="chip-premium">Produto</div>
        <h1 class="mt-6 text-4xl md:text-6xl font-black tracking-tight text-premium-ink" style="text-wrap: balance;">
          <span class="block sm:inline">Menos no‑show, <span class="text-brand-blue">mais conversão</span></span>
          <span class="block sm:inline"><span aria-hidden="true">—</span><span class="sr-only"> — </span> com diagnóstico grátis em 30 min e automação <span class="text-brand-purple">24/7</span>.</span>
        </h1>
        <p class="mt-5 text-lg md:text-xl text-gray-700 max-w-2xl">
          Diagnóstico grátis em 30 min + proposta automática personalizada. Acabe com o caos no WhatsApp e feche mais vendas sem esforço manual.
        </p>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl">
          <div class="card-premium p-5">
            <div class="text-sm text-gray-500">Resultado</div>
            <div class="mt-1 font-bold text-premium-ink">Menos no‑show e mais conversão</div>
          </div>
          <div class="card-premium p-5">
            <div class="text-sm text-gray-500">Operação</div>
            <div class="mt-1 font-bold text-premium-ink">Respostas rápidas e consistentes</div>
          </div>
          <div class="card-premium p-5">
            <div class="text-sm text-gray-500">Controle</div>
            <div class="mt-1 font-bold text-premium-ink">Leads organizados e rastreáveis</div>
          </div>
          <div class="card-premium p-5">
            <div class="text-sm text-gray-500">Sinalização</div>
            <div class="mt-1 font-bold text-premium-ink">Alertas em tempo real</div>
          </div>
        </div>

        <!-- Trust bar -->
        <div class="mt-10">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 card-premium p-5 bg-white/70 backdrop-blur">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-brand-blue">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="text-sm font-semibold text-premium-ink">Atendimento 24/7</div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-brand-purple">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>
              </div>
              <div class="text-sm font-semibold text-premium-ink">Diagnóstico 30 min</div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-amber-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>
              </div>
              <div class="text-sm font-semibold text-premium-ink">Proposta em minutos</div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-green-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <div class="text-sm font-semibold text-premium-ink">Garantia de prazo</div>
            </div>
          </div>
        </div>

        <!-- removed: internal workflow note -->
      </div>

      <div class="lg:col-span-5">
        <div class="card-premium p-7 md:p-8">
          <div class="text-center">
            <div class="chip-premium">Diagnóstico</div>
            <h2 class="mt-4 text-2xl font-black text-premium-ink">Preencha e receba uma proposta em minutos</h2>
            <p class="mt-2 text-gray-600">Sem compromisso — se não enxergarmos ganho claro, a gente te diz.</p>
          </div>

          <div class="mt-6 grid grid-cols-1 gap-4">
            <button id="openLead247" type="button" class="btn-primary w-full">Quero meu diagnóstico grátis AGORA (30 min)</button>
          </div>

          <!-- Carousel (fade, auto) -->
          <div class="mt-6">
            <div id="lead247Carousel" class="relative rounded-2xl border border-gray-200 overflow-hidden bg-gray-50">
              <div class="lead247-slide opacity-100">
                <img class="w-full h-auto" src="/assets/img/carousel/slide-1.jpg" alt="Exemplo de negócio" loading="lazy" decoding="async" />
              </div>
              <div class="lead247-slide opacity-0">
                <img class="w-full h-auto" src="/assets/img/carousel/slide-2.jpg" alt="Exemplo de atendimento" loading="lazy" decoding="async" />
              </div>
              <div class="lead247-slide opacity-0">
                <img class="w-full h-auto" src="/assets/img/carousel/slide-3.jpg" alt="Exemplo de operação" loading="lazy" decoding="async" />
              </div>
              <div class="lead247-slide opacity-0">
                <img class="w-full h-auto" src="/assets/img/carousel/slide-4.jpg" alt="Exemplo de serviço" loading="lazy" decoding="async" />
              </div>

              <button type="button" class="lead247-nav left-3" aria-label="Anterior" data-dir="prev">‹</button>
              <button type="button" class="lead247-nav right-3" aria-label="Próximo" data-dir="next">›</button>

              <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
                <button type="button" class="lead247-dot" aria-label="Slide 1" data-idx="0"></button>
                <button type="button" class="lead247-dot" aria-label="Slide 2" data-idx="1"></button>
                <button type="button" class="lead247-dot" aria-label="Slide 3" data-idx="2"></button>
                <button type="button" class="lead247-dot" aria-label="Slide 4" data-idx="3"></button>
              </div>
            </div>

            <style>
              #lead247Carousel .lead247-slide{position:absolute; inset:0; transition:opacity .5s ease;}
              #lead247Carousel{padding-top:56%;}
              #lead247Carousel img{position:absolute; inset:0; width:100%; height:100%; object-fit:cover;}
              #lead247Carousel .lead247-nav{position:absolute; top:50%; transform:translateY(-50%); width:40px; height:40px; border-radius:9999px; background:rgba(255,255,255,.85); border:1px solid rgba(229,231,235,1); color:#0f172a; font-size:26px; line-height:1; display:flex; align-items:center; justify-content:center;}
              #lead247Carousel .lead247-nav:hover{background:white;}
              #lead247Carousel .lead247-dot{width:10px; height:10px; border-radius:9999px; border:1px solid rgba(229,231,235,1); background:rgba(255,255,255,.65);}
              #lead247Carousel .lead247-dot.is-active{background:rgba(106,90,249,1); border-color:rgba(106,90,249,1);}
              @media (prefers-reduced-motion: reduce){
                #lead247Carousel .lead247-slide{transition:none;}
              }
            </style>
          </div>
        </div>
      </div>

      <dialog id="lead247Modal" class="w-[min(860px,96vw)] rounded-2xl p-0 backdrop:bg-black/60">
        <div class="card-premium p-6 md:p-8">
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="chip-premium">Diagnóstico</div>
              <h3 class="mt-4 text-2xl md:text-3xl font-black text-premium-ink">Agendar diagnóstico (30 min)</h3>
              <p class="mt-2 text-gray-600">Preencha abaixo. Você recebe uma proposta automática por e-mail.</p>
            </div>
            <button id="closeLead247" type="button" class="btn-secondary">Fechar</button>
          </div>

          <form id="lead247" class="mt-6 grid grid-cols-1 gap-4">
            <label class="block">
              <span class="text-sm font-semibold text-premium-ink">Seu nome</span>
              <input name="name" required class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-blue/40" placeholder="Alex" />
            </label>

            <label class="block">
              <span class="text-sm font-semibold text-premium-ink">E-mail</span>
              <input name="email" type="email" required class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-blue/40" placeholder="voce@empresa.com" />
            </label>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-sm font-semibold text-premium-ink">WhatsApp (opcional)</span>
                <input name="phone" class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-blue/40" placeholder="(11) 9xxxx-xxxx" />
              </label>

              <label class="block">
                <span class="text-sm font-semibold text-premium-ink">Nicho</span>
                <select name="nicho" class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 bg-white focus:outline-none focus:ring-2 focus:ring-brand-blue/40">
                  {NICHOS.map((n) => <option value={n}>{n}</option>)}
                </select>
              </label>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-sm font-semibold text-premium-ink">Objetivo principal</span>
                <select name="goal" class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 bg-white focus:outline-none focus:ring-2 focus:ring-brand-blue/40">
                  <option value="agendamento">Agendamento</option>
                  <option value="orcamento">Orçamento</option>
                  <option value="suporte">Suporte / Dúvidas</option>
                  <option value="followup">Follow-up / Reativação</option>
                </select>
              </label>

              <label class="block">
                <span class="text-sm font-semibold text-premium-ink">Volume (mês)</span>
                <select name="volume" class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 bg-white focus:outline-none focus:ring-2 focus:ring-brand-blue/40">
                  <option value="ate_30">Até 30</option>
                  <option value="31_100">31–100</option>
                  <option value="100_plus">100+</option>
                </select>
              </label>
            </div>

            <label class="block">
              <span class="text-sm font-semibold text-premium-ink">Canal</span>
              <select name="channel" class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 bg-white focus:outline-none focus:ring-2 focus:ring-brand-blue/40">
                <option value="site_email">Site + E-mail</option>
                <option value="whatsapp">WhatsApp</option>
                <option value="ambos">Site + WhatsApp</option>
              </select>
            </label>

            <label class="block">
              <span class="text-sm font-semibold text-premium-ink">Descreva o caso (1–2 frases)</span>
              <textarea name="message" required rows={4} class="mt-2 w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-blue/40" placeholder="Ex.: Quero agendamento + confirmação automática e reduzir no-show." />
            </label>

            <label class="hidden" aria-hidden="true">
              <span>Website</span>
              <input name="website" tabindex="-1" autocomplete="off" />
            </label>

            <label class="flex items-start gap-3 text-sm text-gray-600">
              <input name="consent" type="checkbox" required class="mt-1" />
              <span>Autorizo o uso dos dados para retorno do contato (LGPD).</span>
            </label>

            <button type="submit" class="btn-primary w-full">Receber proposta automática</button>
            <p id="lead247_status" class="text-sm text-gray-600"></p>
          </form>

          <div class="mt-6 text-xs text-gray-500">
            Ao enviar, você recebe a proposta por e-mail e registramos o lead automaticamente.
          </div>
        </div>
      </dialog>
    </div>
  </div>

  <script is:inline define:vars={{ WEBHOOK_URL }}>
    (function () {
      const form = document.getElementById('lead247');
      const statusEl = document.getElementById('lead247_status');
      if (!form) return;

      // injected by Astro via define:vars
      const webhookUrl = WEBHOOK_URL;

      const modal = document.getElementById('lead247Modal');
      const openBtn = document.getElementById('openLead247');
      const closeBtn = document.getElementById('closeLead247');

      // Mini-monitoramento (sem analytics externo): page view + cliques no CTA + submits (enviado no payload)
      const METRICS_KEY = 'lead247_metrics_v1';
      const todayKey = new Date().toISOString().slice(0, 10); // YYYY-MM-DD

      function loadMetrics() {
        try {
          const raw = localStorage.getItem(METRICS_KEY);
          const data = raw ? JSON.parse(raw) : {};
          if (!data[todayKey]) data[todayKey] = { pageViews: 0, ctaClicks: 0, submits: 0 };
          return data;
        } catch {
          return { [todayKey]: { pageViews: 0, ctaClicks: 0, submits: 0 } };
        }
      }

      function saveMetrics(data) {
        try {
          localStorage.setItem(METRICS_KEY, JSON.stringify(data));
        } catch {}
      }

      const metrics = loadMetrics();
      // count one page view per browser session (avoid overcount on reload spam)
      if (!sessionStorage.getItem('lead247_pv_counted')) {
        metrics[todayKey].pageViews += 1;
        sessionStorage.setItem('lead247_pv_counted', '1');
        saveMetrics(metrics);
      }

      function openModal() {
        if (!modal) return;
        if (typeof modal.showModal === 'function') modal.showModal();
        else modal.setAttribute('open', '');
      }

      function closeModal() {
        if (!modal) return;
        if (typeof modal.close === 'function') modal.close();
        else modal.removeAttribute('open');
      }

      openBtn?.addEventListener('click', () => {
        const m = loadMetrics();
        m[todayKey].ctaClicks += 1;
        saveMetrics(m);
        openModal();
      });
      closeBtn?.addEventListener('click', closeModal);
      modal?.addEventListener('click', (e) => {
        // close when clicking backdrop
        if (e.target === modal) closeModal();
      });

      // Fade carousel (auto)
      const carousel = document.getElementById('lead247Carousel');
      const slides = carousel?.querySelectorAll('.lead247-slide');
      const dots = carousel?.querySelectorAll('.lead247-dot');
      const navs = carousel?.querySelectorAll('.lead247-nav');
      if (carousel && slides?.length) {
        let idx = 0;
        let timer;

        const setIdx = (next) => {
          idx = (next + slides.length) % slides.length;
          slides.forEach((el, i) => el.style.opacity = i === idx ? '1' : '0');
          dots?.forEach((d, i) => d.classList.toggle('is-active', i === idx));
        };

        const start = () => {
          if (window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches) return;
          stop();
          timer = window.setInterval(() => setIdx(idx + 1), 3500);
        };

        const stop = () => {
          if (timer) window.clearInterval(timer);
        };

        dots?.forEach((d) => {
          d.addEventListener('click', () => {
            const n = Number(d.getAttribute('data-idx'));
            if (!Number.isNaN(n)) setIdx(n);
            start();
          });
        });

        navs?.forEach((b) => {
          b.addEventListener('click', () => {
            const dir = b.getAttribute('data-dir');
            setIdx(dir === 'prev' ? idx - 1 : idx + 1);
            start();
          });
        });

        carousel.addEventListener('mouseenter', stop);
        carousel.addEventListener('mouseleave', start);

        setIdx(0);
        start();
      }

      // Autoplay may be blocked on some browsers until a user gesture; try start.
      document.querySelectorAll('video[autoplay]').forEach((v) => {
        try { v.play?.(); } catch {}
      });

      function setStatus(msg, kind) {
        statusEl.textContent = msg;
        statusEl.className = 'text-sm ' + (kind === 'ok' ? 'text-green-700' : kind === 'err' ? 'text-red-700' : 'text-gray-600');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        setStatus('Enviando…', '');

        const data = Object.fromEntries(new FormData(form).entries());
        const m = loadMetrics();
        const payload = {
          name: String(data.name || ''),
          email: String(data.email || ''),
          phone: String(data.phone || ''),
          company: String(data.company || ''),
          nicho: String(data.nicho || ''),
          goal: String(data.goal || ''),
          volume: String(data.volume || ''),
          channel: String(data.channel || ''),
          message: String(data.message || ''),
          website: String(data.website || ''),
          consent: data.consent === 'on',
          source: 'site_form',
          pageUrl: window.location.href,
          createdAt: new Date().toISOString(),
          metrics: {
            date: todayKey,
            pageViews: m[todayKey]?.pageViews ?? null,
            ctaClicks: m[todayKey]?.ctaClicks ?? null,
          },
        };

        try {
          const res = await fetch(webhookUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!res.ok) throw new Error('HTTP ' + res.status);
          // increment submit counter (local)
          const mm = loadMetrics();
          mm[todayKey].submits += 1;
          saveMetrics(mm);

          setStatus('Recebido! Redirecionando…', 'ok');
          // small delay so the user sees the confirmation
          setTimeout(() => {
            window.location.href = '/obrigado/';
          }, 450);
          form.reset();
        } catch (err) {
          console.error(err);
          setStatus('Falhou ao enviar. Tente novamente em alguns segundos.', 'err');
        }
      });
    })();
  </script>
</section>
