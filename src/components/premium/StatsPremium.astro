---
const { stats = [] } = Astro.props;
---

<section class="py-14 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 text-center">
      {stats.map((s) => (
        <div>
          <div class="text-5xl md:text-6xl font-black tracking-tight bg-gradient-to-r from-brand-purple to-brand-blue bg-clip-text text-transparent">
            {s.value}
          </div>
          <div class="mt-2 text-gray-600 font-semibold">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
