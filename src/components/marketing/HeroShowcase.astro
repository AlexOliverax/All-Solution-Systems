---
const slides = [
  {
    k: 'agendamento',
    title: 'Agendamento 24/7 no WhatsApp',
    desc: 'Triagem + confirmação + lembretes + handoff para humano.',
    href: '/agendamento/',
    badge: 'Agendamento',
  },
  {
    k: 'b20',
    title: 'Tecnologia B20',
    desc: 'Telemetria, gestão e operação com visão de sistema.',
    href: '/b20/',
    badge: 'Produto',
  },
  {
    k: 'integracoes',
    title: 'Integrações que cortam trabalho',
    desc: 'Webhooks, APIs, planilhas, automações e painéis.',
    href: '/servicos/',
    badge: 'Serviços',
  },
];

const photos = [
  '/assets/img/hero/fac87004-ba4b-4160-a1b6-1da6c769ade4.webp',
  '/assets/img/hero/bd982957-53ca-460d-a019-6053ddbe6e9e.webp',
  '/assets/img/hero/5ff13b6a-3a75-4c39-bac7-d76656bf4145.webp',
  '/assets/img/hero/366fea26-76e6-498e-9c82-f528736b86a0.webp',
  '/assets/img/hero/automation-flow-v3.webp',
];
---

<section class="relative overflow-hidden bg-white">
  <!-- Photo fade backdrop (CSS-only; no JS dependency) -->
  <div class="pointer-events-none absolute inset-0">
    <div class="hero-photos absolute inset-0" style="--hero-count: 5;">
      {photos.map((src, i) => (
        <div
          class="hero-photo"
          style={`--hero-img: url(${src}); --hero-i: ${i};`}
          aria-hidden="true"
        />
      ))}
    </div>

    <!-- overlay for readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 to-white/30 lg:to-white/10"></div>
    <div class="absolute inset-0 opacity-[0.10] [background-image:radial-gradient(#111_1px,transparent_1px)] [background-size:18px_18px]"></div>
  </div>

  <div class="container mx-auto px-4 pt-24 pb-14 lg:pt-28 lg:pb-20 relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <div class="rounded-3xl bg-white/55 backdrop-blur-sm border border-gray-200/60 shadow-[0_18px_50px_rgba(0,0,0,0.06)] p-5 md:p-7 max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white/80 backdrop-blur px-3 py-1 text-xs font-semibold text-gray-700">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          Você entra. A dor sai. O processo fica.
        </div>

        <h1 class="mt-5 text-5xl md:text-6xl font-black tracking-tight text-dark">
          A sensação de
          <span class="text-primary"> “agora vai”</span>
          <br class="hidden sm:block" />
          no seu atendimento.
        </h1>

        <p class="mt-5 text-lg md:text-xl text-gray-700 max-w-2xl leading-relaxed">
          Menos caos no WhatsApp. Mais clareza. Mais conversão. Com produtos e automações que cabem no seu negócio.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="https://wa.me/5511968628280?text=Oi!%20Vim%20do%20site%20da%20All%20Solution%20Systems.%20Quero%20entender%20qual%20produto/servi%C3%A7o%20resolve%20minha%20dor.%20Meu%20nicho%20%C3%A9%20%5Bnicho%5D%20e%20atendo%20em%20%5Bbairro%5D." target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full sm:w-auto focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500">
            Falar no WhatsApp
          </a>
          <a href="#explorar" class="btn-secondary w-full sm:w-auto bg-white/80 backdrop-blur focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
            Explorar soluções
          </a>
        </div>

        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
          <div class="rounded-brutalist border-2 border-dark bg-white/85 backdrop-blur px-4 py-3 shadow-[6px_6px_0px_#111]">
            <div class="font-black text-dark">24/7</div>
            <div class="text-gray-700">triagem</div>
          </div>
          <div class="rounded-brutalist border-2 border-dark bg-white/85 backdrop-blur px-4 py-3 shadow-[6px_6px_0px_#111]">
            <div class="font-black text-dark">+velocidade</div>
            <div class="text-gray-700">menos vai‑e‑volta</div>
          </div>
          <div class="hidden sm:block rounded-brutalist border-2 border-dark bg-white/85 backdrop-blur px-4 py-3 shadow-[6px_6px_0px_#111]">
            <div class="font-black text-dark">+conversão</div>
            <div class="text-gray-700">menos no‑show</div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="rounded-brutalist border-4 border-dark bg-white/75 backdrop-blur-sm shadow-[14px_14px_0px_#135bec] p-5">
          <div class="flex items-center justify-between">
            <div class="text-xs font-black uppercase tracking-wider text-gray-500">Comece por aqui</div>
            <div class="text-xs font-semibold text-gray-500">clique para ver</div>
          </div>

          <div class="mt-4 space-y-3">
            {slides.map((s) => (
              <a href={s.href} class="group block rounded-brutalist border-2 border-dark/10 hover:border-dark transition-colors bg-white p-4 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                <div class="flex items-center justify-between gap-3">
                  <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-1 text-xs font-bold">
                    {s.badge}
                  </span>
                  <span class="text-xs text-gray-500 group-hover:text-dark">Ver →</span>
                </div>
                <div class="mt-2 text-lg font-black text-dark leading-snug">{s.title}</div>
                <div class="mt-1 text-sm text-gray-700">{s.desc}</div>
              </a>
            ))}
          </div>

          <div class="mt-4 text-xs text-gray-600">
            Dica: comece por <a href="/agendamento/" class="text-primary underline">Agendamento</a> se você recebe muitas mensagens.
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .hero-photos { opacity: 1; }
    .hero-photo {
      position: absolute;
      inset: 0;
      background-image: var(--hero-img);
      background-size: cover;
      background-position: center;
      filter: saturate(1.05) contrast(1.05);
      opacity: 0;
      transform: scale(1.02);
      animation: heroFade calc(var(--hero-count) * 5s) infinite;
      animation-delay: calc(var(--hero-i) * 5s);
    }
    @keyframes heroFade {
      0% { opacity: 0; }
      6% { opacity: 1; }
      25% { opacity: 1; }
      32% { opacity: 0; }
      100% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-photo { animation: none; opacity: 1; }
      .hero-photos .hero-photo:not(:first-child) { display: none; }
    }
  </style>
</section>
