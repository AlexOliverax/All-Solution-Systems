---
// Simple, no-deps hero background rotator + product teaser cards
// Props: none (keeps MVP); can be expanded later.
const slides = [
  {
    k: 'agendamento',
    title: 'Agendamento 24/7 no WhatsApp',
    desc: 'Triagem + confirmação + lembretes + handoff para humano.',
    href: '/agendamento/',
    badge: 'Agendamento',
  },
  {
    k: 'b20',
    title: 'Tecnologia B20',
    desc: 'Telemetria, gestão e operação com visão de sistema.',
    href: '/b20/',
    badge: 'Produto',
  },
  {
    k: 'integracoes',
    title: 'Integrações que cortam trabalho',
    desc: 'Webhooks, APIs, planilhas, automações e painéis.',
    href: '/servicos/',
    badge: 'Serviços',
  },
];
---

<section class="relative overflow-hidden bg-white">
  <!-- Animated backdrop (no images required) -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-24 -left-24 h-80 w-80 rounded-full bg-primary/15 blur-3xl animate-[pulse_6s_ease-in-out_infinite]"></div>
    <div class="absolute top-20 -right-28 h-96 w-96 rounded-full bg-emerald-400/15 blur-3xl animate-[pulse_7.5s_ease-in-out_infinite]"></div>
    <div class="absolute bottom-[-6rem] left-1/3 h-[28rem] w-[28rem] rounded-full bg-amber-300/15 blur-3xl animate-[pulse_8.5s_ease-in-out_infinite]"></div>
    <div class="absolute inset-0 opacity-[0.10] [background-image:radial-gradient(#111_1px,transparent_1px)] [background-size:18px_18px]"></div>
  </div>

  <div class="container mx-auto px-4 pt-24 pb-14 lg:pt-28 lg:pb-20 relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white/70 backdrop-blur px-3 py-1 text-xs font-semibold text-gray-700">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          Resposta rápida • Automação estável • Sem enrolação
        </div>

        <h1 class="mt-5 text-5xl md:text-6xl font-black tracking-tight text-dark">
          Entre. Veja. Sinta:
          <span class="text-primary"> o alívio</span>.
        </h1>

        <p class="mt-5 text-lg md:text-xl text-gray-600 max-w-2xl leading-relaxed">
          A All Solution Systems cria produtos e automações que tiram o caos do seu atendimento e transformam conversas em próxima ação.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="https://wa.me/5511968628280?text=Oi!%20Vim%20do%20site%20da%20All%20Solution%20Systems.%20Quero%20entender%20qual%20produto/servi%C3%A7o%20resolve%20minha%20dor.%20Meu%20nicho%20%C3%A9%20%5Bnicho%5D%20e%20atendo%20em%20%5Bbairro%5D." target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full sm:w-auto">
            Falar no WhatsApp
          </a>
          <a href="#explorar" class="btn-secondary w-full sm:w-auto">
            Explorar soluções
          </a>
        </div>

        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
          <div class="rounded-brutalist border-2 border-dark bg-white px-4 py-3 shadow-[6px_6px_0px_#111]">
            <div class="font-black text-dark">24/7</div>
            <div class="text-gray-600">triagem</div>
          </div>
          <div class="rounded-brutalist border-2 border-dark bg-white px-4 py-3 shadow-[6px_6px_0px_#111]">
            <div class="font-black text-dark">+velocidade</div>
            <div class="text-gray-600">menos vai‑e‑volta</div>
          </div>
          <div class="hidden sm:block rounded-brutalist border-2 border-dark bg-white px-4 py-3 shadow-[6px_6px_0px_#111]">
            <div class="font-black text-dark">+conversão</div>
            <div class="text-gray-600">menos no‑show</div>
          </div>
        </div>
      </div>

      <!-- Right: carousel cards -->
      <div class="lg:col-span-5">
        <div class="rounded-brutalist border-4 border-dark bg-white shadow-[14px_14px_0px_#135bec] p-5">
          <div class="flex items-center justify-between">
            <div class="text-xs font-black uppercase tracking-wider text-gray-500">Demonstrações</div>
            <div class="text-xs font-semibold text-gray-500">clique para ver</div>
          </div>

          <div class="mt-4 space-y-3" id="hero-cards">
            {slides.map((s) => (
              <a href={s.href} class="group block rounded-brutalist border-2 border-dark/10 hover:border-dark transition-colors bg-white p-4">
                <div class="flex items-center justify-between gap-3">
                  <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-1 text-xs font-bold">
                    {s.badge}
                  </span>
                  <span class="text-xs text-gray-500 group-hover:text-dark">Ver →</span>
                </div>
                <div class="mt-2 text-lg font-black text-dark leading-snug">{s.title}</div>
                <div class="mt-1 text-sm text-gray-600">{s.desc}</div>
              </a>
            ))}
          </div>

          <div class="mt-4 text-xs text-gray-500">
            Dica: comece por <a href="/agendamento/" class="text-primary underline">Agendamento</a> se você recebe muitas mensagens.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
