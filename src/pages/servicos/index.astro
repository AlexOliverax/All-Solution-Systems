---
import MainLayout from '../../layouts/MainLayout.astro';
import { getWhatsAppUrl, CONTACT_INFO } from '../../assets/js/contact-utils';

const waUrl = getWhatsAppUrl(CONTACT_INFO.whatsapp.defaultMessage);
---

<MainLayout title="Soluções e Serviços" description="Conheça todos os serviços de tecnologia e integração da All Solution Systems.">
  <section class="container" style="padding: var(--spacing-12) var(--spacing-4);">
    <h1>Nossos Serviços</h1>
    <p style="margin-top: var(--spacing-4); margin-bottom: var(--spacing-8); color: var(--color-text-muted); max-width: 700px;">
      Desenvolvemos arquiteturas tecnológicas para empresas que desejam escalar. Nossas soluções são divididas entre produtos (B20, Agendamentos) e Integrações dedicadas.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--spacing-6);">
      <!-- Card mock 1 -->
      <article style="padding: var(--spacing-6); border: 1px solid var(--color-border); border-radius: var(--radius-md);">
        <h3>Sistemas de Agendamento</h3>
        <p style="color: var(--color-text-muted); margin-top: var(--spacing-2); margin-bottom: var(--spacing-4);">
          Atenda seus leads automaticamente. Integração direta com sua agenda Google e funil de CRM.
        </p>
        <a href="/agendamento" style="color: var(--color-primary); font-weight: 500;">Saber mais &rarr;</a>
      </article>

      <!-- Card mock 2 -->
      <article style="padding: var(--spacing-6); border: 1px solid var(--color-border); border-radius: var(--radius-md);">
        <h3>Produtos B20</h3>
        <p style="color: var(--color-text-muted); margin-top: var(--spacing-2); margin-bottom: var(--spacing-4);">
          Ecossistema completo de gestão comercial e rastreamento.
        </p>
        <a href="/b20" style="color: var(--color-primary); font-weight: 500;">Saber mais &rarr;</a>
      </article>

      <!-- Card mock 3 -->
      <article style="padding: var(--spacing-6); border: 1px solid var(--color-border); border-radius: var(--radius-md);">
        <h3>Soluções Sob Medida</h3>
        <p style="color: var(--color-text-muted); margin-top: var(--spacing-2); margin-bottom: var(--spacing-4);">
           Aplicações robustas concebidas especialmente para a operação da sua indústria ou negócio local.
        </p>
        <a href={waUrl} target="_blank" style="color: var(--color-whatsapp); font-weight: 500;">Falar no WA &rarr;</a>
      </article>
    </div>
  </section>
</MainLayout>
