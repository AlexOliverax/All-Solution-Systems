---
import MainLayout from '../../layouts/MainLayout.astro';
import { getWhatsAppUrl } from '../../assets/js/contact-utils';

const whatsappUrl = getWhatsAppUrl('Olá, gostaria de saber mais sobre o escopo dos serviços que a All Solution Systems oferece.');
---

<MainLayout 
  title="Serviços de Engenharia de Software" 
  description="Consultoria, desenvolvimento, arquitetura e integrações via All Solution Systems."
>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-dark mb-6 tracking-tight">Expertise Direcionada</h1>
        <p class="text-xl text-gray-600">Não somos uma agência digital. Somos uma assessoria de engenharia de software especializada na otimização profunda dos fluxos de dados do seu ecossistema.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Servico 1 -->
        <div class="p-8 border border-gray-200 rounded-brutalist hover:border-primary transition-colors bg-gray-50 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-bold text-dark mb-4">Software Dedicado (SaaS B2B)</h2>
            <p class="text-gray-600 mb-6">Desenvolvemos plataformas escalares que nascem preparadas para lidar com alta concorrência e big data. Utilizando cloud-native patterns.</p>
          </div>
        </div>

        <!-- Servico 2 -->
        <div class="p-8 border border-gray-200 rounded-brutalist hover:border-primary transition-colors bg-gray-50 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-bold text-dark mb-4">Automação de Backoffice</h2>
            <p class="text-gray-600 mb-6">Integrações robustas para erradicar o trabalho manual da sua equipe, interligando CRMs, ERPs e ferramentas financeiras com fluxos seguros.</p>
          </div>
        </div>
      </div>
      
      <div class="text-center mt-16">
         <a href={whatsappUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">Solicitar Análise de Escopo</a>
      </div>
    </div>
  </section>
</MainLayout>
