---
import MainLayout from '../../layouts/MainLayout.astro';
import { getWhatsAppUrl } from '../../assets/js/contact-utils';

const whatsappUrl = getWhatsAppUrl('Desejo confirmar meu diagnóstico/agendamento.');
---

<MainLayout 
  title="Consultoria B20: Agendamento" 
  description="Assista ao briefing técnico e inicie o diagnóstico da sua empresa para hiperintegração baseada no protocolo B20."
>
  <section class="min-h-screen bg-dark text-white relative flex items-center pt-24 pb-12">
    <div class="container mx-auto px-4 z-10">
      
      <div class="text-center mb-12">
        <span class="inline-block py-1 px-3 bg-primary text-white text-sm font-bold tracking-wider uppercase mb-6 rounded-brutalist">Passo 1 de 2</span>
        <h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">
          O Ponto de Virada <span class="text-primary">Estratégico</span>
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Assista ao briefing técnico abaixo onde explicamos rapidamente o que precisamos de você. Em seguida faça a confirmação do Agendamento Rápido no botão ao lado.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start max-w-6xl mx-auto">
        <!-- Coluna de Vídeo (mock de celular no desktop) -->
        <div class="w-full flex justify-center lg:justify-start">
          <div class="relative w-full max-w-[360px] sm:max-w-[380px]">
            <!-- Phone frame -->
            <div class="relative rounded-[2.2rem] border-[10px] border-[#0B0F1A] bg-[#0B0F1A] shadow-2xl overflow-hidden">
              <!-- Notch -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 mt-2 h-6 w-32 rounded-full bg-black/70"></div>

              <!-- Screen -->
              <div class="bg-black">
                <video
                  class="w-full aspect-[9/16] bg-black object-contain"
                  preload="metadata"
                  playsinline
                  controls
                  poster="/assets/img/agendamento-cover.webp"
                >
                  <source src="/assets/video/agendamento-0227.mp4" type="video/mp4" />
                  Seu navegador não suporta a visualização deste vídeo.
                </video>
              </div>
            </div>

            <!-- small caption -->
            <p class="mt-3 text-xs text-gray-500">Demonstração (visual mobile) • 52s</p>
          </div>
        </div>

        <!-- Coluna de Mini Form (Confirmar no WhatsApp via Fallback HTML) -->
        <div class="bg-white text-dark p-8 md:p-10 rounded-brutalist border-t-8 border-primary shadow-xl">
          <h2 class="text-2xl font-black mb-6">Confirmar Agendamento</h2>
          <p class="text-gray-600 mb-8 leading-relaxed text-sm">
            Nossa agenda funciona por triagem. Clique no botão abaixo para ser direcionado ao ambiente seguro do WhatsApp Oficial, onde um humano real avaliará seu cenário em 15 segundos.
          </p>

          <form action={whatsappUrl} method="get" target="_blank" class="flex flex-col gap-6 relative">
            <!-- Hidden Input transfer as message to wa.me if using JS, fallback ignores and triggers GET on href anyway -->
            
            <div class="flex flex-col gap-2">
              <label for="nome" class="text-sm font-bold uppercase tracking-wider text-gray-500">Seu Nome / Cargo</label>
              <input type="text" id="nome" name="nome" placeholder="Ex: João - CTO" required class="w-full p-4 bg-gray-50 border border-gray-200 rounded-soft focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
            </div>

            <div class="flex flex-col gap-2">
              <label for="empresa" class="text-sm font-bold uppercase tracking-wider text-gray-500">Qual é a Empresa?</label>
              <input type="text" id="empresa" name="empresa" placeholder="Site ou nome da empresa" required class="w-full p-4 bg-gray-50 border border-gray-200 rounded-soft focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
            </div>

            <!-- Fixo DoD: Botão sem JS pra garantir fallback -->
            <button type="submit" class="btn-primary w-full shadow-lg group">
              <span class="flex items-center gap-3">
                Continuar no WhatsApp
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </span>
            </button>
            <p class="text-xs text-center text-gray-400 mt-2">Duração média: 15s • Direto com especialista</p>
          </form>
        </div>
      </div>

    </div>
  </section>
</MainLayout>
