---
import MainLayout from '../../layouts/MainLayout.astro';
import { getWhatsAppUrl } from '../../assets/js/contact-utils';

const whatsappUrl = getWhatsAppUrl('Quero analisar a integração da arquitetura B20 na minha infraestrutura hoje.');
---

<MainLayout 
  title="Framework B20 | Automação e Componentização Avançada" 
  description="Visão profunda técnica sobre como o protocolo B20 viabiliza integração segura de ponta a ponta"
>
  <section class="py-32 bg-dark text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto flex flex-col items-center text-center">
        <div class="w-16 h-16 bg-primary rounded-brutalist mb-8 shadow-[8px_8px_0px_#e8effd]"></div>
        
        <span class="inline-block py-1 px-4 bg-gray-800 text-gray-300 text-sm font-bold tracking-[0.2em] uppercase mb-6 rounded-soft border border-gray-700">Flagship Protocol</span>
        
        <h1 class="text-5xl md:text-7xl font-black mb-8 leading-none">O Ecossistema <br/><span class="text-primary-light text-primary border-b-8 border-primary">B20</span></h1>
        
        <p class="text-xl md:text-2xl text-gray-400 mb-16 leading-relaxed">
          Estrutura proprietária testada no fogo, com pipelines de orquestração construídas para garantir estabilidade absoluta, alta governança e performance zero-latency nas áreas críticas da sua operação.
        </p>

        <a href={whatsappUrl} class="btn-primary text-lg px-8 py-4" target="_blank" rel="noopener noreferrer">Requisitar Documentação Técnica</a>
      </div>
    </div>
  </section>
</MainLayout>
