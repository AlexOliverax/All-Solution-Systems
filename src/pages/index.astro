---
import MainLayout from '../layouts/MainLayout.astro';
import HeroShowcase from '../components/marketing/HeroShowcase.astro';
import Steps3Premium from '../components/premium/Steps3Premium.astro';
import StatsPremium from '../components/premium/StatsPremium.astro';
---

<MainLayout
  title="Soluções em Automação e Engenharia Inteligente"
  description="A All Solution Systems conecta seu negócio ao futuro com soluções sob medida de engenharia de software, automação e arquitetura digital."
>
  <HeroShowcase />

  <StatsPremium
    stats={[
      { value: '100%', label: 'Operação orientada a evidência' },
      { value: '24h', label: 'Ritmo de execução (quando aplicável)' },
      { value: '∞', label: 'Espaço para otimizar o seu fluxo' },
    ]}
  />

  <Steps3Premium
    title="Como destravamos seu fluxo"
    subtitle="Processo simples"
    steps={[
      {
        n: '01',
        icon: '📩',
        title: 'Entenda a dor',
        desc: 'Você descreve o cenário (sem jargão). A gente identifica o gargalo real e o caminho curto.',
      },
      {
        n: '02',
        icon: '🧩',
        title: 'Monte a ponte',
        desc: 'Integração + automação + padrões. Menos retrabalho, mais previsibilidade.',
      },
      {
        n: '03',
        icon: '📈',
        title: 'Meça e melhore',
        desc: 'Acompanhe resultados e itere. O objetivo é reduzir caos e aumentar conversão.',
      },
    ]}
  />

  <section id="explorar" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <div class="chip-premium">Para você</div>
        <h2 class="mt-6 text-4xl md:text-5xl font-black tracking-tight text-premium-ink">Escolha por dor, não por buzzword</h2>
        <p class="mt-4 text-gray-600 text-lg">Entre por uma solução e veja exemplos e próximos passos.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/agendamento/" class="card-premium p-8 hover:-translate-y-0.5 transition-transform">
          <div class="chip-premium">Agendamento</div>
          <h3 class="mt-5 text-2xl font-black text-premium-ink">WhatsApp sem caos</h3>
          <p class="mt-3 text-gray-600">Triagem, confirmação, lembretes e handoff quando precisa.</p>
          <div class="mt-6 font-semibold text-brand-blue">Ver demo →</div>
        </a>

        <a href="/b20/" class="card-premium p-8 hover:-translate-y-0.5 transition-transform">
          <div class="chip-premium">B20</div>
          <h3 class="mt-5 text-2xl font-black text-premium-ink">Bridge To Developers</h3>
          <p class="mt-3 text-gray-600">Devs + testadores + processo: evidência real para melhorar antes do lançamento.</p>
          <div class="mt-6 font-semibold text-brand-blue">Explorar →</div>
        </a>

        <a href="/servicos/" class="card-premium p-8 hover:-translate-y-0.5 transition-transform">
          <div class="chip-premium">Serviços</div>
          <h3 class="mt-5 text-2xl font-black text-premium-ink">Integrações e automações</h3>
          <p class="mt-3 text-gray-600">Webhooks, APIs, planilhas, automações e painéis com robustez.</p>
          <div class="mt-6 font-semibold text-brand-blue">Ver serviços →</div>
        </a>
      </div>

      <div class="mt-14 card-premium p-10 bg-gradient-to-r from-brand-purple/10 to-brand-blue/10">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
          <div>
            <h3 class="text-2xl md:text-3xl font-black text-premium-ink">Pronto para destravar sua operação?</h3>
            <p class="mt-2 text-gray-600">Fale direto com especialista e saia com um próximo passo claro.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
            <a class="btn-whatsapp w-full md:w-auto" href="https://wa.me/5511968628280?text=Ol%C3%A1%2C%20vim%20pelo%20site%20e%20quero%20um%20diagn%C3%B3stico%20para%20destravar%20meu%20processo." target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a>
            <a class="btn-secondary w-full md:w-auto" href="/contato/">Contato</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
