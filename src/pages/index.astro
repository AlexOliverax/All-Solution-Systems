---
import MainLayout from '../layouts/MainLayout.astro';
import Lead247Hero from '../components/product/Lead247Hero.astro';
import Steps3Premium from '../components/premium/Steps3Premium.astro';
---

<MainLayout
  title="Diagnóstico Grátis 30 min | Atendimento 24/7"
  description="Diagnóstico gratuito (30 min) + proposta automática para organizar seu atendimento e aumentar conversão — 24/7."
>
  <Lead247Hero />

  <Steps3Premium
    title="Como funciona"
    subtitle="Automação simples, resultado claro"
    steps={[
      {
        n: '01',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a4 4 0 0 1-4 4H7l-4 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/><path d="M7 8h10"/><path d="M7 12h6"/></svg>`,
        title: 'Captura no site',
        desc: 'Você coleta o pedido do cliente e já começa a atender com rapidez e consistência.',
      },
      {
        n: '02',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect x="4" y="8" width="16" height="12" rx="3"/><path d="M9 14h.01"/><path d="M15 14h.01"/><path d="M10 11h4"/></svg>`,
        title: 'Qualifica e organiza',
        desc: 'IA tria e organiza automaticamente em segundos — você ganha padrão e não perde cliente por demora no retorno.',
      },
      {
        n: '03',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M3.262 15.326A2 2 0 0 0 4 17h16a2 2 0 0 0 .738-1.674C19.63 14.84 18 13.5 18 11V9a6 6 0 1 0-12 0v2c0 2.5-1.63 3.84-2.738 4.326"/></svg>`,
        title: 'Você só decide',
        desc: 'Você sabe o que está acontecendo e só entra quando realmente precisa. 24/7.',
      },
    ]}
  />

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <div class="chip-premium">Prova</div>
        <h2 class="mt-6 text-4xl md:text-5xl font-black tracking-tight text-premium-ink">Resultados típicos por nicho</h2>
        <p class="mt-3 text-sm text-gray-500">*Varia por operação.</p>
        <p class="mt-4 text-gray-600 text-lg">Sem promessas vazias: estes são impactos comuns quando o atendimento passa a ter triagem, registro e resposta 24/7.</p>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card-premium p-7">
          <div class="flex items-center justify-between gap-4">
            <div class="chip-premium">Estética</div>
            <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-brand-blue">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            </div>
          </div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Menos no‑show</h3>
          <p class="mt-2 text-gray-600">Redução típica de <strong>até 75%</strong> no no‑show com confirmações e follow‑ups automáticos <span class="text-gray-500">(varia por operação)</span>.</p>
        </div>
        <div class="card-premium p-7">
          <div class="flex items-center justify-between gap-4">
            <div class="chip-premium">Clínica / Pet</div>
            <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-brand-purple">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a4 4 0 0 1-4 4H7l-4 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/><path d="M7 8h10"/><path d="M7 12h6"/></svg>
            </div>
          </div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Resposta rápida 24h</h3>
          <p class="mt-2 text-gray-600">Tempo de resposta típico <strong>&lt; 2 min</strong> e leads quentes organizados no pipeline <span class="text-gray-500">(varia por volume)</span>.</p>
        </div>
        <div class="card-premium p-7">
          <div class="flex items-center justify-between gap-4">
            <div class="chip-premium">Assistência</div>
            <div class="w-10 h-10 rounded-2xl bg-white border border-premium-stroke flex items-center justify-center text-amber-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14.7 6.3-2.4-2.4a2 2 0 0 0-2.8 0L6.3 7.1a2 2 0 0 0 0 2.8l2.4 2.4"/><path d="m7.8 7.8 8.4 8.4"/><path d="M19 21l-2-2"/><path d="M17 19l2-2"/></svg>
            </div>
          </div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Orçamentos em minutos</h3>
          <p class="mt-2 text-gray-600">Orçamentos enviados automaticamente e menos perda de cliente por demora no retorno <span class="text-gray-500">(varia por operação)</span>.</p>
        </div>
      </div>

      <div class="mt-10 card-premium p-7 md:p-8 bg-gradient-to-r from-brand-purple/10 to-brand-blue/10">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <div class="chip-premium">Como medimos</div>
            <h3 class="mt-4 text-2xl font-black text-premium-ink">Métricas que acompanham a operação</h3>
            <p class="mt-2 text-gray-600">Métricas observadas em operações reais — resultados variam conforme nicho, volume de mensagens e implementação.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 w-full md:w-auto">
            <div class="bg-white/70 backdrop-blur rounded-2xl border border-premium-stroke p-4">
              <div class="text-sm text-gray-500">Tempo de resposta</div>
              <div class="mt-1 text-xl font-black text-premium-ink">&lt; 2 min</div>
            </div>
            <div class="bg-white/70 backdrop-blur rounded-2xl border border-premium-stroke p-4">
              <div class="text-sm text-gray-500">No‑show</div>
              <div class="mt-1 text-xl font-black text-premium-ink">até 80%</div>
              <div class="mt-1 text-xs text-gray-500">redução típica</div>
            </div>
            <div class="bg-white/70 backdrop-blur rounded-2xl border border-premium-stroke p-4">
              <div class="text-sm text-gray-500">Leads organizados</div>
              <div class="mt-1 text-xl font-black text-premium-ink">100%</div>
              <div class="mt-1 text-xs text-gray-500">com histórico</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="garantia" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card-premium p-7">
          <div class="chip-premium">Prazo</div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">MVP em 3–7 dias</h3>
          <p class="mt-2 text-gray-600">Após aprovação e acesso aos itens necessários (canal, agenda e regras).</p>
        </div>

        <div class="card-premium p-7">
          <div class="chip-premium">Garantia</div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Garantia de prazo do MVP</h3>
          <p class="mt-2 text-gray-600">Se não entregarmos o <strong>MVP combinado</strong> no prazo, devolvemos o setup.</p>
        </div>

        <div class="card-premium p-7">
          <div class="chip-premium">Escopo</div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">MVP combinado</h3>
          <p class="mt-2 text-gray-600">Formulário → proposta por e-mail + ajustes por nicho.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="nichos" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <div class="chip-premium">Nicho</div>
        <h2 class="mt-6 text-4xl md:text-5xl font-black tracking-tight text-premium-ink">O produto é o mesmo. O exemplo muda.</h2>
        <p class="mt-4 text-gray-600 text-lg">
          Você escolhe o nicho no formulário e a automação adapta a triagem e o encaminhamento.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card-premium p-7">
          <div class="chip-premium">Estética</div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Agendamento + confirmação</h3>
          <p class="mt-2 text-gray-600">Reduz no-show, organiza horários e melhora o atendimento.</p>
        </div>
        <div class="card-premium p-7">
          <div class="chip-premium">Clínica</div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Triagem + encaminhamento</h3>
          <p class="mt-2 text-gray-600">Perguntas certas antes da equipe gastar tempo.</p>
        </div>
        <div class="card-premium p-7">
          <div class="chip-premium">Assistência</div>
          <h3 class="mt-4 text-xl font-black text-premium-ink">Orçamento estruturado</h3>
          <p class="mt-2 text-gray-600">Coleta modelo/problema e já prepara o atendimento.</p>
        </div>
      </div>

      <div class="mt-12 card-premium p-10 bg-gradient-to-r from-brand-purple/10 to-brand-blue/10">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
          <div>
            <h3 class="text-2xl md:text-3xl font-black text-premium-ink">Quer ver rodando?</h3>
            <p class="mt-2 text-gray-600">Preencha o formulário acima. Em seguida, ajustamos para o seu negócio.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
            <a class="btn-secondary w-full md:w-auto" href="#lead247">Testar agora</a>
            <a class="btn-whatsapp w-full md:w-auto" href="https://wa.me/5511968628280?text=Ol%C3%A1%2C%20vim%20pelo%20site%20e%20quero%20o%20produto%20Atendimento%2024%2F7." target="_blank" rel="noopener noreferrer">WhatsApp</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
