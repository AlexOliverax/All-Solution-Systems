---
import MainLayout from '../layouts/MainLayout.astro';
import HeroShowcase from '../components/marketing/HeroShowcase.astro';
import { getWhatsAppUrl, CONTACT_INFO } from '../assets/js/contact-utils';

const whatsappUrl = getWhatsAppUrl('Olá, vim pela Home do site e gostaria de conversar com um especialista.');
const telegramUrl = CONTACT_INFO.telegram.url;
---

<MainLayout title="Soluções em Automação e Engenharia Inteligente | All Solution Systems" description="A All Solution Systems conecta seu negócio ao futuro com soluções sob medida de engenharia de software, automação e arquitetura digital.">
  <HeroShowcase />

  <section id="explorar" class="py-20 bg-dark text-white">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-end justify-between gap-6">
        <div class="max-w-3xl">
          <h2 class="text-4xl md:text-5xl font-black tracking-tight">Escolha por dor, não por buzzword</h2>
          <p class="mt-4 text-gray-300 text-lg">Toque em uma solução e veja exemplos e próximos passos.</p>
        </div>
        <a href="/servicos/" class="text-primary-light hover:text-white border-b-2 border-primary-light font-bold pb-1 transition-colors">Todos os Serviços →</a>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <a href="/agendamento/" class="group bg-dark-light p-8 rounded-brutalist border border-gray-800 hover:border-primary transition-colors block">
          <h3 class="text-2xl font-black mb-2 group-hover:text-primary transition-colors">Agendamento Automatizado</h3>
          <p class="text-gray-400">WhatsApp-first. Triagem, confirmação, lembretes e handoff quando precisa.</p>
          <span class="inline-block mt-6 font-bold text-sm tracking-widest uppercase group-hover:translate-x-2 transition-transform">Ver demo +</span>
        </a>
        <a href="/produtos/" class="group bg-white text-dark p-8 rounded-brutalist border-2 border-transparent hover:border-primary transition-colors block shadow-[8px_8px_0px_#135bec]">
          <h3 class="text-2xl font-black mb-2">Produtos</h3>
          <p class="text-gray-600">Soluções prontas e evolutivas. Cada uma com uma promessa clara.</p>
          <span class="inline-block mt-6 font-bold text-sm tracking-widest uppercase group-hover:translate-x-2 transition-transform text-primary">Explorar +</span>
        </a>
        <a href="/b20/" class="group bg-dark-light p-8 rounded-brutalist border border-gray-800 hover:border-primary transition-colors block">
          <h3 class="text-2xl font-black mb-2 group-hover:text-primary transition-colors">B20</h3>
          <p class="text-gray-400">Tecnologia e operação com visão de sistema. Para quem quer escala e controle.</p>
          <span class="inline-block mt-6 font-bold text-sm tracking-widest uppercase group-hover:translate-x-2 transition-transform">Ver +</span>
        </a>
      </div>
    </div>
  </section>
</MainLayout>

