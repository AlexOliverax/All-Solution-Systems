---
import MainLayout from '../../layouts/MainLayout.astro';
import { getWhatsAppUrl } from '../../assets/js/contact-utils';

const whatsappUrl = getWhatsAppUrl('Gostaria de aplicar um dos casos de uso de vocês na minha operação.');
---

<MainLayout 
  title="Casos de Uso Multi-Nicho" 
  description="Exemplos reais de aplicação da nossa tecnologia nos setores Automotivo, Financeiro e Retail."
>
  <section class="py-24 bg-white h-screen flex flex-col justify-center">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-black text-dark tracking-tighter mb-6">Em breve: <span class="text-primary">Masterclass</span></h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-12">Estamos preparando os compilados dos estudos de casos blindados que realizamos nos últimos anos focados em eficiência algorítmica.</p>
      
      <a href={whatsappUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">Seja Avisado Primeiro</a>
    </div>
  </section>
</MainLayout>
